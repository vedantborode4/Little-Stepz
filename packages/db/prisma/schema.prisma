generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  AFFILIATE
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  password     String
  name         String
  phone        String?
  role         Role     @default(USER)

  referralCode String?  @unique
  referredById String?
  referredBy   User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referrals    User[]   @relation("UserReferrals")

  addresses     Address[]
  cartItems     CartItem[]
  wishlistItem  WishlistItem[]
  orders        Order[]
  reviews       Review[]
  affiliate     Affiliate?
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([role])
  @@index([referralCode])
}

model RefreshToken {
  id                String   @id @default(uuid())
  tokenHash         String   @unique
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  expiresAt         DateTime
  revoked           Boolean  @default(false)

  replacedByTokenId String?
  replacedByToken   RefreshToken? @relation("TokenRotation", fields: [replacedByTokenId], references: [id])
  replacedTokens    RefreshToken[] @relation("TokenRotation")

  deviceId          String?
  ipAddress         String?
  userAgent         String?

  createdAt DateTime @default(now())
  lastUsedAt DateTime?

  @@index([userId])
}

model Address {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  name      String
  phone     String
  address   String
  city      String
  state     String
  pincode   String
  country   String  @default("India")
  isDefault Boolean @default(false)

  orders    Order[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Category {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  parentId    String?

  parent    Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children  Category[] @relation("CategoryTree")
  products  Product[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id          String   @id @default(uuid())
  name        String
  slug        String   @unique
  description String?
  price       Decimal  @db.Decimal(12,2)
  quantity    Int      @default(0)
  inStock     Boolean  @default(true)
  categoryId  String

  category     Category      @relation(fields: [categoryId], references: [id])
  images       ProductImage[]
  variants     Variant[]
  cartItems    CartItem[]
  wishlistItem WishlistItem[]
  orderItems   OrderItem[]
  reviews      Review[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
  @@index([categoryId])
  @@index([deletedAt])
}

model ProductImage {
  id        String @id @default(uuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  url       String
  publicId  String
  alt       String?
  sortOrder Int @default(0)

  deletedAt DateTime?

  createdAt DateTime @default(now())
}

model Variant {
  id        String   @id @default(uuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  name   String
  price  Decimal? @db.Decimal(12,2)
  stock  Int      @default(0)

  cartItems  CartItem[]
  orderItems OrderItem[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([productId, name])
}

model CartItem {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  sessionId String?

  productId String
  product   Product @relation(fields: [productId], references: [id])
  variantId String?
  variant   Variant? @relation(fields: [variantId], references: [id])

  quantity Int @default(1)

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId, variantId])
  @@unique([sessionId, productId, variantId])
  @@index([sessionId])
}

model WishlistItem {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id])

  deletedAt DateTime?

  createdAt DateTime @default(now())

  @@unique([userId, productId])
}

enum CouponType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Coupon {
  id            String      @id @default(uuid())
  code          String      @unique
  type          CouponType
  value         Decimal     @db.Decimal(12,2)
  minOrderValue Decimal?    @db.Decimal(12,2)
  maxDiscount   Decimal?    @db.Decimal(12,2)
  usageLimit    Int?
  usedCount     Int         @default(0)

  validFrom DateTime?
  validUntil DateTime?
  isActive   Boolean @default(true)

  orders Order[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  OUT_FOR_DELIVERY
  DELIVERED
  CANCELLED
  RETURN_REQUESTED
  RETURN_APPROVED
  RETURN_REJECTED
  RETURNED
  REFUND_INITIATED
  REFUNDED
}

enum PaymentMethod {
  ONLINE
  COD
}

model Order {
  id        String @id @default(uuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id])

  addressId String
  address   Address @relation(fields: [addressId], references: [id])

  couponId String?
  coupon   Coupon? @relation(fields: [couponId], references: [id])

  subtotal        Decimal @db.Decimal(12,2)
  discount        Decimal @default(0) @db.Decimal(12,2)
  shippingCharges Decimal @default(0) @db.Decimal(12,2)
  total           Decimal @db.Decimal(12,2)

  status        OrderStatus   @default(PENDING)
  paymentMethod PaymentMethod @default(ONLINE)

  shiprocketOrderId    String?
  shiprocketShipmentId String?
  trackingUrl          String?
  awbCode              String?

  customerNote String?
  adminNote    String?

  items                OrderItem[]
  payment              Payment?
  reviews              Review[]
  affiliateConversions AffiliateConversion[]
  commissions          Commission[]
  returns              Return[]
  shipments            Shipment[]

  affiliateId String?
  affiliate   Affiliate? @relation(fields: [affiliateId], references: [id])

  idempotencyKey String @unique

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([idempotencyKey])
  @@index([paymentMethod])
  @@index([affiliateId])
}


enum PaymentStatus {
  PENDING
  INITIATED
  SUCCESS
  FAILED
  REFUND_INITIATED
  REFUNDED
  PARTIALLY_REFUNDED
}

model Payment {
  id      String @id @default(uuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  method  PaymentMethod @default(ONLINE)
  gateway String        // "razorpay" | "cod"

  razorpayOrderId   String? @unique
  razorpayPaymentId String? @unique
  razorpaySignature String?

  amount   Decimal @db.Decimal(12,2)
  currency String  @default("INR")
  status   PaymentStatus @default(PENDING)

  refundId     String?
  refundAmount Decimal? @db.Decimal(12,2)
  refundedAt   DateTime?
  refundReason String?

  codCollectedAt DateTime?

  gatewayResponse Json?

  attempts Int @default(0)

  paymentIdempotencyKey String? @unique

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gateway, razorpayOrderId])
  @@index([razorpayPaymentId])
  @@index([status])
  @@index([paymentIdempotencyKey])
}


model WebhookEvent {
  id        String @id @default(uuid())
  provider  String
  eventId   String
  eventType String

  payload     Json
  status      WebhookStatus @default(PENDING)
  processedAt DateTime?
  error       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([provider, eventId])
  @@index([provider, eventType])
  @@index([status])
  @@index([createdAt])
}


model OrderItem {
  id        String @id @default(uuid())
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String?
  variant   Variant? @relation(fields: [variantId], references: [id])

  quantity Int
  price    Decimal

  deletedAt DateTime?
}

enum WebhookStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
  SKIPPED
}

model AuditLog {
  id     String  @id @default(uuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  action   String
  entity   String
  entityId String

  oldValue Json?
  newValue Json?
  metadata Json?

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([entity, entityId])
  @@index([action])
  @@index([createdAt])
}

model Return {
  id      String @id @default(uuid())
  orderId String @unique
  order   Order  @relation(fields: [orderId], references: [id])
  userId  String

  reason      String
  description String?
  status      ReturnStatus @default(PENDING)

  adminNote  String?
  resolvedBy String?
  resolvedAt DateTime?

  refundAmount Decimal?
  refundedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

enum ReturnStatus {
  PENDING
  APPROVED
  REJECTED
  REFUNDED
}

model Shipment {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  shiprocketOrderId    String?
  shiprocketShipmentId String?
  awbCode              String?
  courierName          String?
  trackingUrl          String?

  status      ShipmentStatus @default(PENDING)
  estimatedAt DateTime?
  deliveredAt DateTime?

  trackingData Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([orderId])
  @@index([awbCode])
  @@index([status])
}

enum ShipmentStatus {
  PENDING
  PROCESSING
  SHIPPED
  IN_TRANSIT
  OUT_FOR_DELIVERY
  DELIVERED
  FAILED
  RETURNED
}

model Review {
  id        String  @id @default(uuid())
  userId    String
  productId String
  orderId   String?

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  order   Order?  @relation(fields: [orderId], references: [id])

  rating     Int
  comment    String?
  isApproved Boolean @default(true)

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId])
  @@index([productId, rating])
}

enum AffiliateStatus {
  PENDING
  APPROVED
  REJECTED
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
}

enum CommissionType {
  PER_ORDER 
  LIFETIME 
}

model Affiliate {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  status         AffiliateStatus @default(PENDING)
  referralCode   String          @unique
  commissionRate Decimal         @default(0.05) // 5% default, configurable 5-10%
  commissionType CommissionType  @default(LIFETIME)

  totalClicks      Int     @default(0)
  totalConversions Int     @default(0)
  totalCommission  Decimal @default(0)

  pendingBalance   Decimal @default(0)  
  paidOutBalance   Decimal @default(0)  

  payoutDetails Json? 


  adminNote  String?
  approvedAt DateTime?
  approvedBy String?

  clicks      AffiliateClick[]
  conversions AffiliateConversion[]
  commissions Commission[]
  withdrawals AffiliateWithdrawal[]
  orders      Order[]

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([referralCode])
}

model AffiliateClick {
  id          String    @id @default(uuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  ip          String?
  userAgent   String?
  referrer    String?
  country     String?  
  sessionId   String?  

  ipDateKey   String? 

  isUnique    Boolean  @default(true)  
  convertedAt DateTime? 

  createdAt DateTime @default(now())

  @@index([affiliateId, createdAt])
  @@index([ipDateKey])
  @@index([affiliateId, isUnique])
}

model AffiliateConversion {
  id          String @id @default(uuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  commission Decimal
  status     CommissionStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([affiliateId, orderId])
  @@index([affiliateId, status])
}

model Commission {
  id          String @id @default(uuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  orderId String
  order   Order  @relation(fields: [orderId], references: [id])

  amount Decimal @db.Decimal(12,2)
  status CommissionStatus @default(PENDING)

  paidAt         DateTime?
  reversedAt     DateTime?
  reversalReason String?

  approvedBy  String?
  approvedAt  DateTime?

  withdrawalId String?
  withdrawal   AffiliateWithdrawal? @relation(fields: [withdrawalId], references: [id])

  deletedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([affiliateId, orderId]) 
  @@index([affiliateId, status])
  @@index([orderId])
  @@index([withdrawalId])
  @@index([status])
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  PAID
  REJECTED
}

model AffiliateWithdrawal {
  id          String    @id @default(uuid())
  affiliateId String
  affiliate   Affiliate @relation(fields: [affiliateId], references: [id], onDelete: Cascade)

  amount         Decimal
  status         WithdrawalStatus @default(PENDING)
  payoutDetails  Json?   
  adminNote      String?
  processedBy    String? 
  processedAt    DateTime?
  transactionRef String? 

  commissions Commission[] 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([affiliateId, status])
  @@index([status])
}

enum BannerPosition {
  HOME_HERO
  HOME_MID
  CATEGORY_TOP
  PRODUCT_SIDEBAR
  CHECKOUT_TOP  
}

model Banner {
  id       String @id @default(uuid())

  title       String
  subtitle    String?
  imageUrl    String
  linkUrl     String?
  altText     String?

  position    BannerPosition @default(HOME_HERO)
  sortOrder   Int            @default(0)
  isActive    Boolean        @default(true)

  startsAt    DateTime?
  endsAt      DateTime?

  targetRole  Role?   

  clickCount  Int     @default(0)
  viewCount   Int     @default(0)

  createdBy   String  
  updatedBy   String? 

  deletedAt   DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([position, isActive])
  @@index([isActive, startsAt, endsAt])
  @@index([deletedAt])
}
