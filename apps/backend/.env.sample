#  Server 
PORT=8000
NODE_ENV=development

#  Auth 
ACCESS_TOKEN_SECRET=your-access-token-secret-min-32-chars
ACCESS_TOKEN_EXPIRES=30m

SALT_ROUNDS=12

REFRESH_TOKEN_BYTES=64
REFRESH_TOKEN_TTL_DAYS=30
REFRESH_TOKEN_SALT_ROUNDS=12

#  Razorpay 
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

#  Shiprocket 
SHIPROCKET_EMAIL=your@email.com
SHIPROCKET_PASSWORD=your-shiprocket-password
SHIPROCKET_PICKUP_LOCATION=Primary

#  Package dimensions (cm/kg) — default for all products ─
SHIPROCKET_PKG_LENGTH=20
SHIPROCKET_PKG_BREADTH=15
SHIPROCKET_PKG_HEIGHT=10
SHIPROCKET_PKG_WEIGHT=0.5

#  COD limits 
COD_MAX_AMOUNT=10000

FRONTEND_URL=https://yourdomain.com
MIN_WITHDRAWAL_AMOUNT=100

#  Cloudinary
CLOUDINARY_CLOUD_NAME=asdf
CLOUDINARY_API_KEY=asdf
CLOUDINARY_API_SECRET=asdf

#production with no SSL
NODE_ENV=production
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

#production with SSL
NODE_ENV=production
COOKIE_SECURE=true
COOKIE_SAMESITE=strict

#dev
NODE_ENV=development
# COOKIE_SECURE not set → defaults to false